<%- include('../partials/header') %>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Convites</title>

  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/pagesCSS/invites.css">
</head>

<body class="page-invites">

  <main class="app-content">

    <h1>Convites</h1>
    <p class="subtitle">Histórico de convites enviados para a sua organização</p>

    <div class="card">
      <% if (invites.length === 0) { %>
        <p class="empty-state">Nenhum convite enviado ainda.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Email</th>
              <th>Enviado em</th>
              <th>Expira em</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% invites.forEach(invite => {
              const now = new Date();
              const expired = !invite.used && new Date(invite.expires_at) <= now;
            %>
            <tr>
              <td><%= invite.email %></td>
              <td><%= new Date(invite.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              <td><%= new Date(invite.expires_at).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              <td>
                <% if (invite.used) { %>
                  <span class="badge badge-done">Concluído</span>
                <% } else if (expired) { %>
                  <span class="badge badge-expired">Expirado</span>
                <% } else { %>
                  <span class="badge badge-pending">Pendente</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

  </main>


</body>
</html>

<%- include('../partials/footer') %>
