    </main>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function showSuccess(message) {
            Swal.fire({ icon: 'success', title: 'Sucesso!', text: message, timer: 2000, showConfirmButton: false });
        }
        function showError(message) {
            Swal.fire({ icon: 'error', title: 'Erro!', text: message });
        }
        function confirmAction(message) {
            return Swal.fire({
                title: 'Tem certeza?', text: message, icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0F2A3D', cancelButtonColor: '#FF6B00',
                confirmButtonText: 'Sim', cancelButtonText: 'Não'
            });
        }
    </script>
</body>
</html>
